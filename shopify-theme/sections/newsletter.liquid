{%- comment -%}
  Newsletter section — native Shopify port of artifacts/moi/src/components/NewsletterSection.tsx

  React → Liquid mapping:
    - useState(email) / onChange ...... native form input (no client state needed)
    - subscribeToNewsletter() API call. {% form 'customer' %} (native customer sign-up, no headless API)
    - status === 'success' .............. form.posted_successfully?
    - status === 'error' / errorMsg ..... form.errors
    - useCustomer() isLoggedIn .......... {{ customer }} (prefills email when logged in)
    - framer-motion whileInView ......... .animate-in (IntersectionObserver in theme.js)

  Tailwind utility classes are retained verbatim so the design renders identically.
{%- endcomment -%}

<section class="relative overflow-hidden px-6 pb-20 md:pb-28 pt-10 md:pt-14">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-24 md:h-36 bg-[linear-gradient(to_bottom,rgba(40,33,29,0),rgba(40,33,29,0.22),rgba(40,33,29,0.5))]"></div>
  <div class="mx-auto max-w-5xl relative">
    <div class="absolute inset-x-8 -top-10 h-24 rounded-full blur-3xl bg-[radial-gradient(circle,rgba(255,255,255,0.26),transparent_70%)] opacity-70"></div>
    <div
      class="animate-in relative overflow-hidden border border-[rgba(255,255,255,0.06)] bg-[linear-gradient(135deg,rgba(251,247,241,0.96)_0%,rgba(242,235,226,0.93)_52%,rgba(233,223,210,0.9)_100%)] shadow-[0_24px_80px_rgba(20,16,12,0.12)]"
      style="box-shadow: inset 0 1px 0 rgba(255,255,255,0.28), 0 24px 80px rgba(20,16,12,0.12);"
    >
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(30,24,20,0.08),transparent_36%),radial-gradient(circle_at_bottom_right,rgba(122,110,100,0.18),transparent_34%)]"></div>
      <div class="absolute inset-0 opacity-35 bg-[linear-gradient(115deg,transparent_0%,rgba(255,255,255,0.55)_44%,transparent_58%)] animate-[moi-shine_7s_ease-in-out_infinite]"></div>
      <div class="relative px-6 py-10 md:px-12 md:py-14">
        <div class="flex flex-col gap-8 md:gap-10">
          <div class="flex items-center gap-3 text-[10px] tracking-[0.35em] uppercase" style="color: #7a6e64;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>
              <path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>
            </svg>
            {{ section.settings.eyebrow | default: 'Moi Newsletter' }}
          </div>

          <div class="max-w-3xl flex flex-col gap-4">
            <p class="font-[Cormorant_Garamond,serif] text-[clamp(2rem,5vw,4.5rem)] leading-[0.92] tracking-[-0.04em] font-semibold text-[#1e1814]">
              {{ section.settings.heading | default: 'Stay in Moi-tion.' }}
            </p>
            <p class="max-w-2xl text-sm md:text-base leading-relaxed font-light" style="color: #5a5048;">
              {{ section.settings.body | default: 'Be the first to discover new versatile tops, fashion drops, and exclusive pieces — delivered straight to your inbox.' }}
            </p>
          </div>

          {%- form 'customer', class: 'max-w-2xl flex flex-col gap-4' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="flex flex-col gap-4 md:flex-row md:items-center">
              <div class="flex-1 px-4 py-4 border border-[rgba(30,24,20,0.12)] bg-white/25 backdrop-blur-sm">
                <div class="flex items-center gap-3">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="color: #1e1814;" aria-hidden="true">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  <div class="min-w-0 flex-1">
                    <p class="text-[10px] tracking-[0.28em] uppercase" style="color: #7a6e64;">
                      Email address
                    </p>
                    <input
                      type="email"
                      name="contact[email]"
                      required
                      placeholder="Email address"
                      value="{{ customer.email | default: '' }}"
                      autocomplete="email"
                      class="newsletter-input checkout-input mt-1 w-full bg-transparent text-sm md:text-base font-light outline-none placeholder:text-[rgba(30,24,20,0.35)]"
                      style="color: #1e1814;"
                    >
                  </div>
                </div>
              </div>
              <button
                type="submit"
                class="relative isolate inline-flex items-center justify-center gap-2 overflow-hidden px-6 py-4 text-[11px] tracking-[0.28em] uppercase font-medium text-white transition-transform duration-300 hover:scale-[1.01] disabled:opacity-60 disabled:hover:scale-100"
                style="background-color: #1e1814; box-shadow: 0 12px 28px rgba(30,24,20,0.2), inset 0 1px 0 rgba(255,255,255,0.12);"
              >
                <span class="absolute inset-0 bg-[linear-gradient(115deg,transparent_0%,rgba(255,255,255,0.42)_46%,transparent_60%)] animate-[moi-shine_6s_ease-in-out_infinite]"></span>
                <span class="relative z-10 flex items-center gap-2">
                  {{ section.settings.button_label | default: 'Subscribe' }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </span>
              </button>
            </div>

            {%- if form.errors -%}
              <p class="text-[11px] tracking-wide" style="color: #a0522d;">
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email | default: 'Something went wrong. Please try again.' }}
              </p>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <p class="text-[11px] tracking-[0.22em] uppercase" style="color: #7a6e64;">
                {{ section.settings.success_text | default: "You're on the list." }}
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow label",  "default": "Moi Newsletter" },
    { "type": "text",     "id": "heading",      "label": "Heading",        "default": "Stay in Moi-tion." },
    { "type": "textarea", "id": "body",         "label": "Body text",      "default": "Be the first to discover new versatile tops, fashion drops, and exclusive pieces — delivered straight to your inbox." },
    { "type": "text",     "id": "button_label", "label": "Button label",   "default": "Subscribe" },
    { "type": "text",     "id": "success_text", "label": "Success message","default": "You're on the list." }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
