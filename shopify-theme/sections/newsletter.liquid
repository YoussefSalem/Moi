{%- comment -%}
  Newsletter section — native Shopify port of artifacts/moi/src/components/NewsletterSection.tsx

  React → Liquid mapping:
    - useState(email) / onChange ........ native <input name="contact[email]"> (no client state)
    - subscribeToNewsletter() API call .. {% form 'customer' %} (native customer sign-up, no headless API)
    - status === 'success' .............. form.posted_successfully?
    - status === 'error' / errorMsg ..... form.errors
    - useCustomer() isLoggedIn .......... {{ customer }} (prefills email when logged in)
    - framer-motion whileInView ......... .animate-in (IntersectionObserver in theme.js)

  Styles live in assets/theme.css under "NEWSLETTER" (Tailwind rewritten into
  theme CSS classes, matching the rest of this theme).
{%- endcomment -%}

<section class="newsletter">
  <div class="newsletter-topfade" aria-hidden="true"></div>
  <div class="newsletter-inner">
    <div class="newsletter-glow" aria-hidden="true"></div>
    <div class="newsletter-card animate-in">
      <div class="newsletter-card-radial" aria-hidden="true"></div>
      <div class="newsletter-shine" aria-hidden="true"></div>
      <div class="newsletter-content">
        <div class="newsletter-stack">
          <div class="newsletter-eyebrow">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>
              <path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>
            </svg>
            {{ section.settings.eyebrow | default: 'Moi Newsletter' }}
          </div>

          <div class="newsletter-heading-group">
            <p class="newsletter-heading">{{ section.settings.heading | default: 'Stay in Moi-tion.' }}</p>
            <p class="newsletter-subtext">{{ section.settings.body | default: 'Be the first to discover new versatile tops, fashion drops, and exclusive pieces — delivered straight to your inbox.' }}</p>
          </div>

          {%- form 'customer', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form-row">
              <div class="newsletter-field">
                <div class="newsletter-field-inner">
                  <svg class="newsletter-mail-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="color: #1e1814;" aria-hidden="true">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  <div class="newsletter-field-body">
                    <p class="newsletter-field-label">Email address</p>
                    <input
                      type="email"
                      name="contact[email]"
                      required
                      placeholder="Email address"
                      value="{{ customer.email | default: '' }}"
                      autocomplete="email"
                      class="newsletter-input"
                    >
                  </div>
                </div>
              </div>
              <button type="submit" class="newsletter-submit">
                <span class="newsletter-submit-shine" aria-hidden="true"></span>
                <span class="newsletter-submit-label">
                  {{ section.settings.button_label | default: 'Subscribe' }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </span>
              </button>
            </div>

            {%- if form.errors -%}
              <p class="newsletter-feedback newsletter-feedback--error">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <p class="newsletter-feedback newsletter-feedback--success">
                {{ section.settings.success_text | default: "You're on the list." }}
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow label",   "default": "Moi Newsletter" },
    { "type": "text",     "id": "heading",      "label": "Heading",         "default": "Stay in Moi-tion." },
    { "type": "textarea", "id": "body",         "label": "Body text",       "default": "Be the first to discover new versatile tops, fashion drops, and exclusive pieces — delivered straight to your inbox." },
    { "type": "text",     "id": "button_label", "label": "Button label",    "default": "Subscribe" },
    { "type": "text",     "id": "success_text", "label": "Success message", "default": "You're on the list." }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
