<section class="hero" id="hero">
  <div class="hero-media">
    {%- if section.settings.video_url != blank -%}
      <video
        class="hero-video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        poster="{%- if section.settings.hero_image != blank -%}{{ section.settings.hero_image | img_url: '1920x1080' }}{%- endif -%}"
      ></video>
    {%- elsif section.settings.hero_image != blank -%}
      <img
        class="hero-image"
        src="{{ section.settings.hero_image | img_url: '1920x1080' }}"
        srcset="{{ section.settings.hero_image | img_url: '768x1024' }} 768w, {{ section.settings.hero_image | img_url: '1440x900' }} 1440w, {{ section.settings.hero_image | img_url: '1920x1080' }} 1920w"
        alt="{{ section.settings.hero_image.alt | default: shop.name }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <div class="hero-placeholder"></div>
    {%- endif -%}
  </div>

  <!-- Gradient overlays -->
  <div class="hero-overlay"></div>
  <div class="hero-vignette"></div>

  <!-- Text content -->
  <div class="hero-content" id="hero-content">
    <p class="hero-label">{{ section.settings.label | default: 'New Drop' }}</p>

    <h1 class="hero-brand">
      {{ section.settings.brand_text | default: 'MOI' }}
      <span class="sr-only"> — Premium Versatile Tops &amp; Fashion</span>
    </h1>

    <p class="hero-headline">{{ section.settings.headline | default: 'Summer Collection — Exclusive Drop' }}</p>

    <p class="hero-subheadline">{{ section.settings.subheadline | default: 'New pieces just launched. Fresh arrivals.' }}</p>

    <a
      href="{{ section.settings.cta_url | default: '#collection' }}"
      class="hero-cta"
    >
      {{ section.settings.cta_text | default: 'Shop Now' }}
    </a>

    <p class="hero-urgency">{{ section.settings.urgency_text | default: 'Delivery in Egypt: 2–4 days' }}</p>
  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <div class="scroll-cue-line"></div>
  </div>
</section>

<!-- Trust bar -->
<div class="trust-bar">
  {%- for block in section.blocks -%}
    {%- if block.type == 'trust_item' -%}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <span class="trust-emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
        <span class="trust-text">{{ block.settings.text }}</span>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  // Parallax on hero image
  (function() {
    const heroMedia = document.querySelector('.hero-media');
    const heroContent = document.getElementById('hero-content');
    if (!heroMedia) return;

    let ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          const scrollY = window.scrollY;
          const heroHeight = document.getElementById('hero').offsetHeight;
          const progress = Math.min(scrollY / heroHeight, 1);

          heroMedia.style.transform = 'translateY(' + (progress * 22) + '%)';
          if (heroContent) {
            heroContent.style.transform = 'translateY(' + (progress * 38) + '%)';
            heroContent.style.opacity = Math.max(0, 1 - progress * 1.6);
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Entrance animations
    const label = document.querySelector('.hero-label');
    const brand = document.querySelector('.hero-brand');
    const headline = document.querySelector('.hero-headline');
    const subheadline = document.querySelector('.hero-subheadline');
    const cta = document.querySelector('.hero-cta');
    const urgency = document.querySelector('.hero-urgency');

    function animate(el, delay) {
      if (!el) return;
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      setTimeout(function() {
        el.style.transition = 'opacity 1s cubic-bezier(0.22,1,0.36,1), transform 1s cubic-bezier(0.22,1,0.36,1)';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, delay);
    }

    animate(label, 200);
    animate(brand, 100);
    animate(headline, 500);
    animate(subheadline, 700);
    animate(cta, 400);
    animate(urgency, 900);

    // Scroll cue animation
    const cueEl = document.querySelector('.scroll-cue-line');
    if (cueEl) {
      setTimeout(function() {
        cueEl.classList.add('animate');
      }, 2400);
    }
  })();
</script>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Direct .mp4 URL for looping background video. Overrides the hero image."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "New Drop"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand display text",
      "default": "MOI"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Summer Collection — Exclusive Drop"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "New pieces just launched. Fresh arrivals."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop Now"
    },
    {
      "type": "text",
      "id": "urgency_text",
      "label": "Urgency line",
      "default": "Delivery in Egypt: 2–4 days"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "⚡" },
        { "type": "text", "id": "text", "label": "Text", "default": "Fast delivery across Egypt" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "trust_item", "settings": { "emoji": "☀️", "text": "New summer drop" } },
        { "type": "trust_item", "settings": { "emoji": "⚡", "text": "Fast delivery across Egypt" } },
        { "type": "trust_item", "settings": { "emoji": "🔥", "text": "Limited stock available" } }
      ]
    }
  ]
}
{% endschema %}
