<section class="cart-page">
  <div class="cart-page-inner">
    <h1 class="cart-page-title">Your Bag</h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty-state">
        <p>Your bag is empty.</p>
        <a href="{{ routes.root_url }}" class="btn-primary">Continue Shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-page-item">
              <a href="{{ item.url }}">
                <img
                  src="{{ item.image | img_url: '160x200', crop: 'center' }}"
                  alt="{{ item.title | escape }}"
                  loading="lazy"
                  class="cart-page-item-img"
                >
              </a>
              <div class="cart-page-item-info">
                <a href="{{ item.url }}" class="cart-page-item-title">{{ item.product.title }}</a>
                {%- if item.variant.title != 'Default Title' -%}
                  <p class="cart-page-item-variant">{{ item.variant.title }}</p>
                {%- endif -%}
                <p class="cart-page-item-price">{{ item.final_price | money }}</p>
                <div class="cart-qty">
                  <button type="button" onclick="updateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
                  <span>{{ item.quantity }}</span>
                  <button type="button" onclick="updateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
                </div>
              </div>
              <button
                type="button"
                class="cart-page-item-remove"
                onclick="updateQty('{{ item.key }}', 0)"
                aria-label="Remove {{ item.title | escape }}"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-page-summary">
          <div class="cart-page-subtotal">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <button type="submit" name="checkout" class="btn-checkout-primary">Proceed to Checkout</button>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

<script>
  function updateQty(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function() { location.reload(); });
  }
</script>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
