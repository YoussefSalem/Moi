<section class="collection-page">
  <div class="collection-page-inner">
    <div class="section-header">
      <h1 class="section-title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="section-subtitle">{{ collection.description }}</p>
      {%- endif -%}
    </div>

    <div class="color-card-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p>No products found.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="btn-secondary">← Previous</a>
        {%- endif -%}
        <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="btn-secondary">Next →</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "settings": []
}
{% endschema %}
