{%- assign collection = collections[section.settings.collection] -%}

<section
  id="{{ section.settings.section_id | default: 'collection' }}"
  class="product-color-section{% if section.settings.dark_bg %} product-color-section--dark{% endif %}"
>
  <div class="product-color-section-inner">

    <!-- Section header -->
    <div class="section-header animate-in">
      <p class="section-label">Collections</p>
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- Product grid -->
    <div class="color-card-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.product_limit | default: 9 -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- assign featured_product = all_products[block.settings.product] -%}
            {%- if featured_product != blank -%}
              {%- render 'product-card', product: featured_product -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product Color Section",
  "settings": [
    { "type": "text",       "id": "section_id",    "label": "Section ID (for scroll links)",  "default": "collection" },
    { "type": "text",       "id": "title",          "label": "Section title",                 "default": "MOI WAVVY" },
    { "type": "textarea",   "id": "subtitle",       "label": "Section subtitle" },
    { "type": "collection", "id": "collection",     "label": "Collection (optional)" },
    { "type": "range",      "id": "product_limit",  "label": "Products to show",              "min": 1, "max": 12, "step": 1, "default": 6 },
    { "type": "checkbox",   "id": "dark_bg",        "label": "Dark background",               "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    { "name": "Product Color Section" }
  ]
}
{% endschema %}
