<section class="ambassador-section">
  <div class="ambassador-inner">

    <div class="section-header animate-in">
      <p class="section-label">{{ section.settings.label | default: 'Join the Community' }}</p>
      <h2 class="section-title">{{ section.settings.title | default: 'Become an Ambassador' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <form
      class="ambassador-form"
      id="ambassador-form"
      method="post"
      action="{{ section.settings.form_endpoint | default: 'https://your-vercel-function.vercel.app/api/ambassador' }}"
      novalidate
    >
      <div class="form-row">
        <div class="form-group">
          <label for="amb-first-name" class="form-label">First name</label>
          <input type="text" id="amb-first-name" name="firstName" class="form-input" required placeholder="Your first name">
        </div>
        <div class="form-group">
          <label for="amb-last-name" class="form-label">Last name</label>
          <input type="text" id="amb-last-name" name="lastName" class="form-input" required placeholder="Your last name">
        </div>
      </div>

      <div class="form-group">
        <label for="amb-email" class="form-label">Email address</label>
        <input type="email" id="amb-email" name="email" class="form-input" required placeholder="hello@example.com">
      </div>

      <div class="form-group">
        <label for="amb-phone" class="form-label">Phone / WhatsApp</label>
        <input type="tel" id="amb-phone" name="phone" class="form-input" placeholder="+20 xxx xxx xxxx">
      </div>

      <div class="form-group">
        <label for="amb-instagram" class="form-label">Instagram handle</label>
        <input type="text" id="amb-instagram" name="instagram" class="form-input" placeholder="@yourusername">
      </div>

      <div class="form-group">
        <label for="amb-tiktok" class="form-label">TikTok handle (optional)</label>
        <input type="text" id="amb-tiktok" name="tiktok" class="form-input" placeholder="@yourusername">
      </div>

      <div class="form-group">
        <label for="amb-followers" class="form-label">Approximate followers</label>
        <select id="amb-followers" name="followers" class="form-input form-select">
          <option value="">Select range</option>
          <option value="1k-5k">1k – 5k</option>
          <option value="5k-20k">5k – 20k</option>
          <option value="20k-100k">20k – 100k</option>
          <option value="100k+">100k+</option>
        </select>
      </div>

      <div class="form-group">
        <label for="amb-city" class="form-label">City</label>
        <input type="text" id="amb-city" name="city" class="form-input" placeholder="Alexandria, Cairo…">
      </div>

      <div class="form-group">
        <label for="amb-message" class="form-label">Tell us about yourself</label>
        <textarea id="amb-message" name="message" class="form-input form-textarea" rows="4" placeholder="Why do you want to be a Moi ambassador?"></textarea>
      </div>

      <button type="submit" class="btn-primary" id="ambassador-submit">Submit Application</button>

      <div class="form-feedback" id="form-feedback" aria-live="polite"></div>
    </form>
  </div>
</section>

<script>
  document.getElementById('ambassador-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('ambassador-submit');
    const feedback = document.getElementById('form-feedback');
    btn.textContent = 'Submitting…';
    btn.disabled = true;
    feedback.textContent = '';
    feedback.className = 'form-feedback';

    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch(this.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await res.json();
      if (res.ok && json.success) {
        feedback.textContent = 'Thank you! Your application has been received.';
        feedback.classList.add('form-feedback--success');
        this.reset();
      } else {
        throw new Error(json.error || 'Something went wrong.');
      }
    } catch (err) {
      feedback.textContent = err.message || 'Something went wrong. Please try again.';
      feedback.classList.add('form-feedback--error');
    } finally {
      btn.textContent = 'Submit Application';
      btn.disabled = false;
    }
  });
</script>

{% schema %}
{
  "name": "Ambassador Form",
  "settings": [
    { "type": "text",     "id": "label",         "label": "Label",         "default": "Join the Community" },
    { "type": "text",     "id": "title",          "label": "Title",         "default": "Become an Ambassador" },
    { "type": "textarea", "id": "subtitle",       "label": "Subtitle" },
    { "type": "text",     "id": "form_endpoint",  "label": "Form endpoint URL (Vercel function)",
      "info": "Deploy resend-function/ to Vercel and paste the URL here." }
  ],
  "presets": [
    { "name": "Ambassador Form" }
  ]
}
{% endschema %}
