modules = ["nodejs-24", "python-3.12", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
AMBASSADOR_EMAIL_TO = "youssefasalem@gmail.com"
RESEND_AUDIENCE_ID = "12395a94-5b31-4b42-aad3-fd329701f987"
BUSINESS_WHATSAPP_NUMBER = "+201200520083"
ADMIN_EMAIL = "youssefasalem@gmail.com"
ADMIN_NOTIFICATION_EMAIL = "youssefasalem@gmail.com"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 18266
externalPort = 80

[[ports]]
localPort = 18267
externalPort = 3000

[[ports]]
localPort = 18269
externalPort = 3001
