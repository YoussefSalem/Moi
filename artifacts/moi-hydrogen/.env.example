# ── Shopify Storefront API ──────────────────────────────────────────────────
# Found in Shopify Admin → Apps → Hydrogen storefront → Storefront API token
PUBLIC_STOREFRONT_API_TOKEN=your_public_storefront_api_token
PRIVATE_STOREFRONT_API_TOKEN=your_private_storefront_api_token
PUBLIC_STORE_DOMAIN=checkout-moi.myshopify.com
PUBLIC_STOREFRONT_ID=your_storefront_id

# ── Shopify Customer Account API ────────────────────────────────────────────
# Found in Shopify Admin → Apps → Customer accounts → API credentials
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your_customer_account_api_client_id
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/authentication/your_shop_id

# ── Session ─────────────────────────────────────────────────────────────────
# A long random string — run: openssl rand -base64 32
SESSION_SECRET=your_session_secret_at_least_32_chars

# ── Express backend (Replit) ─────────────────────────────────────────────────
# The subdomain pointing to Replit (admin.buy-moi.com → Replit app)
PUBLIC_API_ORIGIN=https://admin.buy-moi.com

# ── Analytics ───────────────────────────────────────────────────────────────
PUBLIC_META_PIXEL_ID=your_meta_pixel_id
PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Checkout ─────────────────────────────────────────────────────────────────
# Custom domain used in checkout URL rewriting
PUBLIC_CHECKOUT_DOMAIN=checkout-moi.myshopify.com
