<section id="social-proof" class="moi-tiktok">
  <div class="moi-container">
    <div class="moi-fade-in">
      <div class="moi-tiktok__header">
        <p class="moi-tiktok__label">{{ section.settings.section_label | default: 'TikTok social proof' }}</p>
        <h2 class="moi-tiktok__title">{{ section.settings.section_title | default: 'Styled by you' }}</h2>
        <p class="moi-tiktok__desc">{{ section.settings.section_description | default: 'Real people. Real outfits. See how Moi moves in the wild.' }}</p>
      </div>

      <div class="moi-tiktok__grid-container">
        <div class="moi-tiktok__grid-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          <p>TikTok social proof</p>
        </div>
        <div class="moi-tiktok__grid">
          {% for block in section.blocks %}
            <div class="moi-tiktok__card">
              <p class="moi-tiktok__card-title">{{ block.settings.title }}</p>
              <a href="{{ block.settings.profile_url }}" target="_blank" rel="noopener noreferrer" class="moi-tiktok__card-handle">
                {{ block.settings.handle }}
              </a>
              <p class="moi-tiktok__card-caption">{{ block.settings.caption }}</p>
              <div class="moi-tiktok__card-video">
                {% if block.settings.embed_url != blank %}
                  <iframe
                    title="{{ block.settings.title }}"
                    src="{{ block.settings.embed_url }}"
                    style="width: 100%; aspect-ratio: 9/16; border: none;"
                    allow="fullscreen; clipboard-write; encrypted-media; picture-in-picture; autoplay"
                    scrolling="no"
                    sandbox="allow-scripts allow-same-origin allow-presentation allow-popups allow-popups-to-escape-sandbox allow-forms"
                  ></iframe>
                {% else %}
                  <div style="width: 100%; aspect-ratio: 9/16; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #1f1916 0%, #2a201c 50%, #1f1916 100%);">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.25); margin-bottom: 12px;">
                      <path d="m9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                    </svg>
                    <p style="font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(255,255,255,0.3); font-weight: 500;">Coming soon</p>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "TikTok Social Proof",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "TikTok social proof"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Styled by you"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Section Description",
      "default": "Real people. Real outfits. See how Moi moves in the wild."
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "TikTok Video",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Video Title"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Creator Handle",
          "default": "@shopmoi_"
        },
        {
          "type": "url",
          "id": "profile_url",
          "label": "Profile URL"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "embed_url",
          "label": "TikTok Embed URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TikTok Social Proof",
      "category": "Social",
      "blocks": [
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
