<section id="social-proof" class="py-16 md:py-24 px-6 md:px-12" style="background-color: #faf8f5;">
  <div class="moi-container">
    <div class="moi-fade-in">
      <div class="text-center mb-10 md:mb-14">
        <p class="moi-section-header__label" style="letter-spacing: 0.45em; margin-bottom: 16px; color: rgba(120,108,96,0.55);">
          TikTok social proof
        </p>
        <h2 class="font-serif" style="font-size: clamp(1.8rem, 5vw, 3rem); font-weight: 300; color: #1e1814; line-height: 1.05;">
          Styled by you
        </h2>
        <p class="mt-4 text-sm md:text-base leading-7 max-w-lg mx-auto" style="color: rgba(30,24,20,0.55);">
          Real people. Real outfits. See how Moi moves in the wild.
        </p>
      </div>

      <div class="rounded-3xl p-6 md:p-8 border border-black/10" style="background-color: #1f1916; box-shadow: 0 16px 40px rgba(20,16,12,0.10);">
        <div class="flex items-center gap-3 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/70"><path d="m9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          <p class="text-[10px] tracking-[0.35em] uppercase text-white/50">TikTok social proof</p>
        </div>
        <div class="flex flex-wrap justify-center gap-5">
          {% for block in section.blocks %}
            <div class="w-full md:w-[calc(50%-10px)] lg:w-[calc(33.333%-14px)] max-w-[440px] rounded-2xl border border-white/10 p-4" style="background-color: rgba(255,255,255,0.03);">
              <p class="text-sm text-white/90">{{ block.settings.title }}</p>
              <a href="{{ block.settings.profile_url }}" target="_blank" rel="noopener noreferrer" class="mt-1 inline-block text-[10px] tracking-[0.25em] uppercase text-white/40 hover:text-white/80 transition-colors">
                {{ block.settings.handle }}
              </a>
              <p class="mt-3 text-sm leading-7 text-white/60">{{ block.settings.caption }}</p>
              <div class="mt-4 overflow-hidden rounded-2xl border border-white/10" style="background: #000;">
                <div class="relative overflow-hidden" style="aspect-ratio: 9/16;">
                  {% if block.settings.embed_url != blank %}
                    <iframe
                      title="{{ block.settings.title }}"
                      src="{{ block.settings.embed_url }}"
                      class="absolute left-0 top-0 w-full"
                      style="height: 107%; transform: translateY(-2px);"
                      allow="fullscreen; clipboard-write; encrypted-media; picture-in-picture; autoplay"
                      scrolling="no"
                      sandbox="allow-scripts allow-same-origin allow-presentation allow-popups allow-popups-to-escape-sandbox allow-forms"
                    ></iframe>
                  {% else %}
                    <div class="absolute inset-0 flex flex-col items-center justify-center" style="background: linear-gradient(135deg, #1f1916 0%, #2a201c 50%, #1f1916 100%);">
                      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="text-white/25 mb-3">
                        <path d="m9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                      </svg>
                      <p class="text-[10px] tracking-[0.3em] uppercase text-white/30 font-medium">Coming soon</p>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "TikTok Social Proof",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "TikTok social proof"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Styled by you"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Section Description",
      "default": "Real people. Real outfits. See how Moi moves in the wild."
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "TikTok Video",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Video Title"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Creator Handle",
          "default": "@shopmoi_"
        },
        {
          "type": "url",
          "id": "profile_url",
          "label": "Profile URL"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "embed_url",
          "label": "TikTok Embed URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TikTok Social Proof",
      "category": "Social",
      "blocks": [
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
