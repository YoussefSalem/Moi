<div class="moi-cart-drawer__overlay" id="moi-cart-overlay"></div>
<div class="moi-cart-drawer" id="moi-cart-drawer">
  <div class="moi-cart-drawer__header">
    <span class="moi-cart-drawer__title">Your Cart</span>
    <button class="moi-cart-drawer__close" id="moi-cart-close" aria-label="Close cart">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>
  <div class="moi-cart-drawer__items" id="moi-cart-items">
    <!-- Cart items populated by JS or via cart.js fetch -->
  </div>
  <div class="moi-cart-drawer__footer" id="moi-cart-footer" style="display: none;">
    <div class="moi-cart-drawer__subtotal">
      <span class="moi-cart-drawer__subtotal-label">Subtotal</span>
      <span id="moi-cart-subtotal">0.00 EGP</span>
    </div>
    <a href="/cart" class="moi-cart-drawer__checkout-btn" style="display: block; text-align: center; text-decoration: none;">View Cart</a>
    <a href="/checkout" class="moi-cart-drawer__checkout-btn" style="display: block; text-align: center; text-decoration: none; margin-top: 8px;">Proceed to Checkout</a>
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [],
  "presets": [
    {
      "name": "Cart Drawer"
    }
  ]
}
{% endschema %}
