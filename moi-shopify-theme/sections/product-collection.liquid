{% assign product_collection = section.settings.collection %}
{% assign section_title = section.settings.section_title %}
{% assign section_subtitle = section.settings.section_subtitle %}
{% assign is_dark = section.settings.dark_background %}
{% assign section_id = section.settings.section_id %}

<section id="{{ section_id }}" class="moi-product-section {% if is_dark %}moi-product-section--warm{% else %}moi-product-section--light{% endif %}">
  <div class="moi-container">
    <div class="moi-section-header moi-fade-in">
      <p class="moi-section-header__label">Collections</p>
      <h2 class="moi-section-header__title">{{ section_title }}</h2>
      {% if section_subtitle != blank %}
        <p class="moi-section-header__subtitle">{{ section_subtitle }}</p>
      {% endif %}
      <div class="moi-section-header__divider"></div>
    </div>

    <div class="moi-product-grid">
      {% if product_collection != blank %}
        {% assign grid_products = collections[product_collection].products %}
      {% else %}
        {% assign grid_products = collections.all.products %}
      {% endif %}

      {% if grid_products.size > 0 %}
        {% for product in grid_products %}
          {% for variant in product.variants %}
            {% assign variant_image = variant.featured_image | default: product.featured_image %}
            {% assign color_name = variant.option1 | default: '' %}
            {% assign variant_is_available = variant.available %}
            {% assign variant_low_stock = false %}
            {% if variant.inventory_quantity > 0 and variant.inventory_quantity < 10 %}
              {% assign variant_low_stock = true %}
            {% endif %}
            {% assign swatch_color = color_name | handleize | replace: 'light-blue', '#a8c8d8' | replace: 'navy', '#3a5a7a' | replace: 'mint', '#98c8a8' | replace: 'white', '#f5f0e8' | replace: 'cashmere', '#d4c4b0' | replace: 'beige', '#c8b8a0' | replace: 'yellow', '#e8d080' | replace: 'teal', '#4a8a8a' | replace: 'ivory', '#e3d4cb' | replace: 'blush', '#e8c4b8' | replace: 'sage', '#b0c4a8' | replace: 'sand', '#d4c4a8' | replace: 'rust', '#c87040' %}

            <a href="{{ product.url }}?variant={{ variant.id }}" class="moi-color-card moi-fade-in">
              <div class="moi-color-card__image">
                {% if variant_image != blank %}
                  <img
                    src="{{ variant_image | image_url: width: 600 }}"
                    alt="{{ product.title }}{% if color_name != blank %} — {{ color_name }}{% endif %}"
                    loading="lazy"
                    decoding="async"
                    class="moi-color-card__main-img"
                  >
                {% else %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.title }}"
                    loading="lazy"
                    decoding="async"
                    class="moi-color-card__main-img"
                  >
                {% endif %}
                {% unless variant_is_available %}
                  <div class="moi-color-card__sold-out">
                    <span>Sold Out</span>
                  </div>
                {% endunless %}
              </div>

              <div class="moi-color-card__info">
                <div class="moi-color-card__color-row">
                  {% if color_name != blank %}
                    <span class="moi-color-card__swatch" style="background-color: {{ swatch_color }};"></span>
                    <span class="moi-color-card__color-name">{{ color_name }}</span>
                  {% endif %}
                </div>

                <h3 class="moi-color-card__product-name">{{ product.title }}</h3>

                {% if variant_is_available and variant_low_stock %}
                  <span class="moi-color-card__stock">Only {{ variant.inventory_quantity }} left</span>
                {% endif %}

                <div class="moi-color-card__price">
                  {% if variant.compare_at_price > variant.price %}
                    <span class="moi-color-card__compare">{{ variant.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="moi-color-card__current-price {% if variant.compare_at_price > variant.price %}moi-color-card__current-price--sale{% endif %}">
                    {{ variant.price | money }}
                  </span>
                </div>

                {% if variant_is_available %}
                  <span class="moi-color-card__btn">Order Now</span>
                {% else %}
                  <span class="moi-color-card__btn moi-color-card__btn--sold-out">Sold Out</span>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          <a href="{{ block.settings.product_url }}" class="moi-color-card moi-fade-in">
            <div class="moi-color-card__image">
              <img
                src="{{ block.settings.product_image | image_url: width: 600 }}"
                alt="{{ block.settings.product_title }}"
                loading="lazy"
                decoding="async"
                class="moi-color-card__main-img"
              >
              {% if block.settings.hover_image != blank %}
                <div class="moi-color-card__image-hover">
                  <img
                    src="{{ block.settings.hover_image | image_url: width: 600 }}"
                    alt="{{ block.settings.product_title }} alternate"
                    loading="lazy"
                    decoding="async"
                  >
                </div>
              {% endif %}
              {% if block.settings.sold_out %}
                <div class="moi-color-card__sold-out">
                  <span>Sold Out</span>
                </div>
              {% endif %}
            </div>

            <div class="moi-color-card__info">
              <div class="moi-color-card__color-row">
                {% if block.settings.swatch_color != blank %}
                  <span class="moi-color-card__swatch" style="background-color: {{ block.settings.swatch_color }};"></span>
                {% endif %}
                <span class="moi-color-card__color-name">{{ block.settings.color_name }}</span>
                {% if block.settings.selling_fast %}
                  <span class="moi-color-card__badge">
                    <span class="moi-color-card__badge-dot"></span>
                    <span class="moi-color-card__badge-text">Selling Fast</span>
                  </span>
                {% endif %}
              </div>

              <h3 class="moi-color-card__product-name">{{ block.settings.product_title }}</h3>

              {% unless block.settings.sold_out %}
                {% if block.settings.stock_count > 0 and block.settings.stock_count < 10 %}
                  <span class="moi-color-card__stock">Only {{ block.settings.stock_count }} left</span>
                {% endif %}
              {% endunless %}

              <div class="moi-color-card__price">
                {% if block.settings.compare_price > block.settings.price %}
                  <span class="moi-color-card__compare">{{ block.settings.compare_price | money }}</span>
                {% endif %}
                <span class="moi-color-card__current-price {% if block.settings.compare_price > block.settings.price %}moi-color-card__current-price--sale{% endif %}">
                  {{ block.settings.price | money }}
                </span>
              </div>

              {% if block.settings.sold_out %}
                <span class="moi-color-card__btn moi-color-card__btn--sold-out">Sold Out</span>
              {% else %}
                <span class="moi-color-card__btn">Order Now</span>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Collection",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "collection",
      "info": "Used for anchor links"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "MOI VERSA TOP"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Effortlessly versatile. A silhouette that moves with you, in every shade of summer."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select a collection to auto-show all its product variants as cards"
    },
    {
      "type": "checkbox",
      "id": "dark_background",
      "label": "Dark Background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Card",
      "settings": [
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Title"
        },
        {
          "type": "text",
          "id": "color_name",
          "label": "Color Name"
        },
        {
          "type": "color",
          "id": "swatch_color",
          "label": "Swatch Color"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover Image"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product URL"
        },
        {
          "type": "number",
          "id": "price",
          "label": "Price (cents)"
        },
        {
          "type": "number",
          "id": "compare_price",
          "label": "Compare Price (cents)"
        },
        {
          "type": "number",
          "id": "stock_count",
          "label": "Stock Count",
          "default": 0
        },
        {
          "type": "checkbox",
          "id": "sold_out",
          "label": "Sold Out",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "selling_fast",
          "label": "Selling Fast",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Collection"
    }
  ]
}
{% endschema %}
