{% assign open_section = 'return' %}

<footer class="moi-footer">
  <div class="moi-footer__inner">
    <!-- Quick Links -->
    <div class="moi-footer__links">
      <a href="/collections/versa-top" class="moi-footer__link">Versa Top</a>
      <a href="/collections/wavvy-top" class="moi-footer__link">Wavvy Top</a>
      <a href="/collections/accessories" class="moi-footer__link">Accessories</a>
      <a href="/pages/ambassador" class="moi-footer__link">Ambassador</a>
      <a href="/collections/all" class="moi-footer__link">Shop All</a>
    </div>

    <!-- Social Links -->
    <div class="moi-footer__social">
      <a href="https://www.instagram.com/shopmoi/" target="_blank" rel="noopener noreferrer" class="moi-footer__social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        <span>Follow us on Instagram</span>
      </a>
      <div class="moi-footer__social-divider"></div>
      <a href="https://www.tiktok.com/@shopmoi_" target="_blank" rel="noopener noreferrer" class="moi-footer__social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
        <span>Follow us on TikTok</span>
      </a>
    </div>

    <!-- About -->
    <div class="moi-footer__about">
      <div>
        <p class="moi-footer__about-label">Moi</p>
        <p class="moi-footer__about-text">Shop versatile tops, elegant clothing, and curated fashion accessories designed for effortless everyday style.</p>
      </div>
    </div>

    <!-- Accordion -->
    <div class="moi-footer__accordion">
      <div class="moi-footer__accordion-item {% if open_section == 'care' %}is-open{% endif %}">
        <button class="moi-footer__accordion-trigger" type="button">
          <div>
            <p class="moi-footer__accordion-title">Care instructions</p>
            <p class="moi-footer__accordion-desc">Handle each piece with care to preserve fit, texture, and finish over time.</p>
          </div>
          <svg class="moi-footer__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="moi-footer__accordion-body">
          <div class="moi-footer__accordion-content">We recommend gentle cleaning, low heat drying, and storing garments away from direct sunlight. For more delicate pieces, professional care is best.</div>
        </div>
      </div>

      <div class="moi-footer__accordion-item {% if open_section == 'return' %}is-open{% endif %}">
        <button class="moi-footer__accordion-trigger" type="button">
          <div>
            <p class="moi-footer__accordion-title">Return policy</p>
            <p class="moi-footer__accordion-desc">Simple returns within the policy window for eligible items.</p>
          </div>
          <svg class="moi-footer__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="moi-footer__accordion-body">
          <div class="moi-footer__accordion-content">Please keep items unworn, with original packaging and tags attached. If you need help with an exchange or return, contact us and we will guide you through the process.</div>
        </div>
      </div>

      <div class="moi-footer__accordion-item {% if open_section == 'shipping' %}is-open{% endif %}">
        <button class="moi-footer__accordion-trigger" type="button">
          <div>
            <p class="moi-footer__accordion-title">Shipping</p>
            <p class="moi-footer__accordion-desc">Fast, tracked delivery with clear timing by region.</p>
          </div>
          <svg class="moi-footer__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="moi-footer__accordion-body">
          <div class="moi-footer__accordion-content">Delivery times vary by location. Orders in Cairo and Giza typically arrive within 3 to 4 days, while governorates may take 5 to 6 working days. Tracking details are shared once your order is processed.</div>
        </div>
      </div>

      <div class="moi-footer__accordion-item {% if open_section == 'contact' %}is-open{% endif %}">
        <button class="moi-footer__accordion-trigger" type="button">
          <div>
            <p class="moi-footer__accordion-title">Contact us</p>
            <p class="moi-footer__accordion-desc">Reach the team for product, order, or policy questions.</p>
          </div>
          <svg class="moi-footer__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="moi-footer__accordion-body">
          <div class="moi-footer__accordion-content">For more inquiries, email Hello@buy-moi.com or use the contact option in the footer menu. We aim to reply as quickly as possible.</div>
        </div>
      </div>
    </div>

    <!-- Newsletter -->
    <div class="moi-newsletter">
      <p class="moi-newsletter__title">Stay in the loop</p>
      <form class="moi-newsletter__form" action="/contact#contact_form" method="post">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="email" name="contact[email]" class="moi-newsletter__input" placeholder="Enter your email" required>
        <button type="submit" class="moi-newsletter__btn">Subscribe</button>
      </form>
    </div>

    <!-- Footer Bottom -->
    <div class="moi-footer__bottom">
      <div class="moi-footer__policies">
        <a href="{{ shop.privacy_policy.url | default: '/policies/privacy-policy' }}" class="moi-footer__policy">Privacy Policy</a>
        <a href="{{ shop.refund_policy.url | default: '/policies/refund-policy' }}" class="moi-footer__policy">Refund Policy</a>
        <a href="{{ shop.refund_policy.url | default: '/policies/refund-policy' }}" class="moi-footer__policy">Return Policy</a>
        <a href="{{ shop.shipping_policy.url | default: '/policies/shipping-policy' }}" class="moi-footer__policy">Delivery Policy</a>
      </div>
      <div class="moi-footer__contact">
        <a href="mailto:hello@buy-moi.com">hello@buy-moi.com</a>
        <span class="moi-footer__contact-divider">|</span>
        <a href="tel:+201200520083">+20 120 052 0083</a>
        <span class="moi-footer__contact-divider">|</span>
        <span>58 Sotar Street, Azarita, Bab Sharq, Alexandria, Egypt</span>
      </div>
      <div class="moi-footer__copyright">
        <p class="moi-footer__copyright-text">© {{ 'now' | date: '%Y' }} Moi. All rights reserved.</p>
        <p class="moi-footer__copyright-text">Smooth, elegant, minimal.</p>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "about_text",
      "label": "About Text",
      "default": "Shop versatile tops, elegant clothing, and curated fashion accessories designed for effortless everyday style."
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/shopmoi/"
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "default": "https://www.tiktok.com/@shopmoi_"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact Email",
      "default": "hello@buy-moi.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Contact Phone",
      "default": "+20 120 052 0083"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "58 Sotar Street, Azarita, Bab Sharq, Alexandria, Egypt"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
