<div class="moi-search-drawer__overlay" id="moi-search-overlay"></div>
<div class="moi-search-drawer" id="moi-search-drawer">
  <div class="moi-search-drawer__header">
    <form action="/search" method="get" style="flex: 1; display: flex; align-items: center;">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" class="moi-search-drawer__input" placeholder="Search products..." autocomplete="off">
    </form>
    <button class="moi-search-drawer__close" id="moi-search-close" aria-label="Close search">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>
  <div class="moi-search-drawer__results" id="moi-search-results">
    <!-- Search results populated by JS -->
  </div>
</div>

{% schema %}
{
  "name": "Search Drawer",
  "settings": [],
  "presets": [
    {
      "name": "Search Drawer"
    }
  ]
}
{% endschema %}
