<div class="moi-page" style="padding-top: 120px;">
  <div class="moi-page__inner">
    <h1 class="moi-page__title">Search</h1>

    <form action="/search" method="get" style="margin-bottom: 48px;">
      <div style="display: flex; gap: 8px; max-width: 500px;">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search products..."
          class="moi-newsletter__input"
          style="flex: 1;"
        >
        <button type="submit" class="moi-cart-drawer__checkout-btn" style="width: auto; padding: 12px 24px;">Search</button>
      </div>
    </form>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <p class="moi-page__content" style="margin-bottom: 24px;">{{ search.results_count }} results found</p>
        <div class="moi-product-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              <div class="moi-grid-2 flex justify-center">
                <a href="{{ item.url }}" class="moi-color-card">
                  <div class="moi-color-card__image">
                    <img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.title }}" loading="lazy">
                  </div>
                  <div class="moi-color-card__info">
                    <h3 class="moi-color-card__product-name">{{ item.title }}</h3>
                    <div class="moi-color-card__price">
                      <span class="moi-color-card__current-price">{{ item.price | money }}</span>
                    </div>
                  </div>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <p class="moi-page__content">No results found for "{{ search.terms | escape }}".</p>
      {% endif %}
    {% endif %}
  </div>
</div>
