<div class="moi-page" style="padding-top: 120px; background: hsl(30 15% 95%);">
  <div class="moi-page__inner" style="max-width: 1000px;">
    <section class="moi-ambassador">
      <p class="moi-ambassador__label">Join Moi</p>
      <h1 class="moi-ambassador__title">Become an Ambassador</h1>
      <p class="moi-ambassador__desc">
        Apply to collaborate with Moi and represent the brand through your content, audience, and personal style.
      </p>
    </section>

    <form id="moi-ambassador-form" class="moi-ambassador__form">
      <div class="moi-ambassador__grid">
        <label class="moi-ambassador__field">
          <span class="moi-ambassador__field-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Full name <span style="color: #c0392b;">*</span>
          </span>
          <input type="text" name="name" placeholder="Your full name" required class="moi-ambassador__input">
        </label>
        <label class="moi-ambassador__field">
          <span class="moi-ambassador__field-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Phone number
          </span>
          <input type="tel" name="phone" placeholder="Phone number" class="moi-ambassador__input">
        </label>
      </div>

      <label class="moi-ambassador__field">
        <span class="moi-ambassador__field-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          Email address <span style="color: #c0392b;">*</span>
        </span>
        <input type="email" name="email" placeholder="Email address" required class="moi-ambassador__input">
      </label>

      <div class="moi-ambassador__grid">
        <label class="moi-ambassador__field">
          <span class="moi-ambassador__field-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            Facebook profile link
          </span>
          <input type="url" name="facebook" placeholder="Optional" class="moi-ambassador__input">
        </label>
        <label class="moi-ambassador__field">
          <span class="moi-ambassador__field-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
            Instagram profile link
          </span>
          <input type="url" name="instagram" placeholder="Optional" class="moi-ambassador__input">
        </label>
      </div>

      <label class="moi-ambassador__field">
        <span class="moi-ambassador__field-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
          Tell us about yourself <span style="color: #c0392b;">*</span>
        </span>
        <textarea name="message" rows="6" placeholder="Describe yourself, your audience, and why you'd like to become an ambassador." required class="moi-ambassador__input moi-ambassador__textarea"></textarea>
      </label>

      <div class="moi-ambassador__actions">
        <button type="submit" class="moi-ambassador__btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"></path><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"></path><circle cx="12" cy="12" r="2"></circle><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"></path><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"></path></svg>
          Apply Now
        </button>
        <span id="moi-ambassador-status" class="moi-ambassador__status"></span>
      </div>
    </form>
  </div>
</div>

<script>
  (function() {
    var form = document.getElementById('moi-ambassador-form');
    var status = document.getElementById('moi-ambassador-status');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('[type="submit"]');
      var originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg> Sending...</span>';
      status.textContent = '';
      status.className = 'moi-ambassador__status';

      var data = {
        name: form.name.value.trim(),
        phone: form.phone.value.trim(),
        email: form.email.value.trim(),
        facebook: form.facebook.value.trim(),
        instagram: form.instagram.value.trim(),
        message: form.message.value.trim()
      };

      fetch('/api/ambassador', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) {
        if (!r.ok) throw new Error('Server error');
        return r.json();
      })
      .then(function() {
        status.textContent = 'Application sent \u2014 we\'ll be in touch!';
        status.classList.add('moi-ambassador__status--success');
        btn.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> Sent!</span>';
        form.reset();
        setTimeout(function() {
          btn.disabled = false;
          btn.innerHTML = originalText;
        }, 3000);
      })
      .catch(function(err) {
        status.textContent = 'Please fill in all required fields and try again.';
        status.classList.add('moi-ambassador__status--error');
        btn.disabled = false;
        btn.innerHTML = originalText;
      });
    });
  })();
</script>
