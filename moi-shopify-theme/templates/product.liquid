{% assign current_variant = product.selected_or_first_available_variant %}
{% assign color_option = product.options_with_values | where: 'name', 'Color' | first %}
{% assign size_option = product.options_with_values | where: 'name', 'Size' | first %}
{% unless size_option %}
  {% assign size_option = product.options_with_values | where: 'name', 'Titre' | first %}
{% endunless %}

<div class="moi-product-page">
  <div class="moi-product-page__grid">
    <!-- Gallery -->
    <div class="moi-product-gallery">
      <div class="moi-product-gallery__main">
        {% if product.images.size > 0 %}
          <img
            id="moi-product-main-image"
            src="{{ product.images[0] | image_url: width: 800 }}"
            alt="{{ product.title }}"
            loading="eager"
            decoding="async"
          >
        {% else %}
          <img src="{{ 'placeholder.png' | asset_url }}" alt="{{ product.title }}">
        {% endif %}
      </div>

      <div class="moi-product-gallery__nav">
        {% for image in product.images %}
          <button
            class="moi-product-gallery__thumb {% if forloop.first %}is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            onclick="document.getElementById('moi-product-main-image').src='{{ image | image_url: width: 800 }}';this.parentElement.querySelectorAll('.moi-product-gallery__thumb').forEach(t=>t.classList.remove('is-active'));this.classList.add('is-active');"
          >
            <img src="{{ image | image_url: width: 200 }}" alt="{{ product.title }} — image {{ forloop.index }}">
          </button>
        {% endfor %}
      </div>
    </div>

    <!-- Info -->
    <div class="moi-product-info">
      <a href="/" class="moi-product-info__back">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
        Back to Collection
      </a>

      <h1 class="moi-product-info__title">{{ product.title }}</h1>
      <p class="moi-product-info__subtitle">{{ product.vendor | default: 'MOI' }}</p>

      <div class="moi-product-info__price">
        <span class="moi-product-info__current-price">{{ current_variant.price | money }}</span>
        {% if current_variant.compare_at_price > current_variant.price %}
          <span class="moi-product-info__compare-price">{{ current_variant.compare_at_price | money }}</span>
        {% endif %}
        {% if current_variant.compare_at_price > current_variant.price %}
          <span class="moi-product-info__sale-badge">
            <span class="moi-product-info__badge-dot"></span>
            Sale
          </span>
        {% endif %}
      </div>

      <div class="moi-product-info__description">
        {{ product.description | strip_html | truncate: 280 }}
      </div>

      <div class="moi-product-info__divider"></div>

      {% form 'product', product, id: 'moi-product-form' %}
        <!-- Color Swatches -->
        {% if color_option %}
          <div>
            <p class="moi-product-info__option-label">Color: <span id="selected-color">{{ current_variant.option1 }}</span></p>
            <div class="moi-product-info__swatches" id="color-swatches">
              {% for value in color_option.values %}
                {% assign variant_for_color = product.variants | where: 'option1', value | first %}
                {% assign is_available = false %}
                {% for v in product.variants %}
                  {% if v.option1 == value and v.available %}
                    {% assign is_available = true %}
                  {% endif %}
                {% endfor %}
                {% assign is_selected = false %}
                {% if current_variant.option1 == value %}
                  {% assign is_selected = true %}
                {% endif %}
                <button
                  type="button"
                  class="moi-product-info__swatch {% if is_selected %}is-selected{% endif %} {% unless is_available %}is-sold-out{% endunless %}"
                  {% if is_available %}
                    onclick="updateVariantByColor('{{ value }}')"
                  {% endif %}
                  style="background-color: {{ value | handleize | replace: 'light-blue', '#a8c8d8' | replace: 'navy', '#3a5a7a' | replace: 'mint', '#98c8a8' | replace: 'white', '#f5f0e8' | replace: 'cashmere', '#d4c4b0' | replace: 'beige', '#c8b8a0' | replace: 'yellow', '#e8d080' | replace: 'teal', '#4a8a8a' | replace: 'ivory', '#e3d4cb' }};"
                  aria-label="Select {{ value }}"
                  title="{{ value }}"
                ></button>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <!-- Size Pills -->
        {% if size_option and size_option.values.size > 1 %}
          <div>
            <p class="moi-product-info__option-label">Size: <span id="selected-size">{{ current_variant.option2 }}</span></p>
            <div class="moi-product-info__sizes" id="size-pills">
              {% for value in size_option.values %}
                {% assign is_available = false %}
                {% for v in product.variants %}
                  {% if v.option2 == value and v.available %}
                    {% assign is_available = true %}
                  {% endif %}
                {% endfor %}
                {% assign is_selected = false %}
                {% if current_variant.option2 == value %}
                  {% assign is_selected = true %}
                {% endif %}
                <button
                  type="button"
                  class="moi-product-info__size {% if is_selected %}is-selected{% endif %} {% unless is_available %}is-unavailable{% endunless %}"
                  {% if is_available %}
                    onclick="updateVariantBySize('{{ value }}')"
                  {% endif %}
                >
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">

        <div class="moi-product-info__stock">
          {% if current_variant.available and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 10 %}
            <span class="moi-product-info__stock-dot"></span>
            <span>Only {{ current_variant.inventory_quantity }} left</span>
          {% endif %}
        </div>

        <button
          type="submit"
          name="add"
          class="moi-product-info__add-btn {% unless current_variant.available %}is-sold-out{% endunless %}"
          id="add-to-cart-btn"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
        </button>
      {% endform %}

      <div class="moi-product-info__details">
        {% if product.metafields.custom.material_outer %}
          <div class="moi-product-info__detail-row">
            <span>Material</span>
            <span>{{ product.metafields.custom.material_outer }}</span>
          </div>
        {% endif %}
        {% if product.metafields.custom.reference %}
          <div class="moi-product-info__detail-row">
            <span>Reference</span>
            <span>{{ product.metafields.custom.reference }}</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  // Variant selection logic
  var variants = {{ product.variants | json }};
  var options = {{ product.options | json }};
  var selectedColor = {{ current_variant.option1 | json }};
  var selectedSize = {{ current_variant.option2 | json }};

  function updateVariantByColor(color) {
    selectedColor = color;
    findAndUpdateVariant();
  }

  function updateVariantBySize(size) {
    selectedSize = size;
    findAndUpdateVariant();
  }

  function findAndUpdateVariant() {
    var found = variants.find(function(v) {
      var colorMatch = !options[0] || v.option1 === selectedColor;
      var sizeMatch = !options[1] || v.option2 === selectedSize;
      return colorMatch && sizeMatch;
    });
    if (found) {
      document.getElementById('variant-id').value = found.id;
      updateUI(found);
    }
  }

  function updateUI(variant) {
    var btn = document.getElementById('add-to-cart-btn');
    if (variant.available) {
      btn.disabled = false;
      btn.classList.remove('is-sold-out');
      btn.textContent = 'Add to Cart';
    } else {
      btn.disabled = true;
      btn.classList.add('is-sold-out');
      btn.textContent = 'Sold Out';
    }
  }
</script>
