<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#faf8f5">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" href="{{ 'moi-theme.css' | asset_url }}" as="style">
  <link rel="stylesheet" href="{{ 'moi-theme.css' | asset_url }}" media="all">

  {%- if template == 'index' -%}
    <title>{{ shop.name }} — Premium Versatile Tops & Fashion</title>
    <meta name="description" content="Shop versatile tops, elegant clothing, and curated fashion accessories designed for effortless everyday style. Summer collection — exclusive drop.">
  {%- else -%}
    <title>{{ page_title }}{% if current_tags %} &mdash; {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &mdash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>
  {%- endif -%}

  {{ content_for_header }}
</head>

<body class="template-{{ template | replace: '.', ' ' | handle }}">
  <a class="sr-only" href="#main-content">Skip to content</a>

  {% section 'header' %}

  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'moi-theme.js' | asset_url }}" defer></script>
  {{ 'shopify/common.js' | shopify_asset_url | script_tag }}
</body>
</html>
